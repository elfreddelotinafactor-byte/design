// Paste these rules into Firebase Console → Firestore → Rules tab, then Publish.
//
// Rules:
//  - Anyone can READ guestbook messages (so they appear on the site).
//  - Anyone can CREATE a guestbook entry (name + text only, size-limited).
//  - RSVPs are NOT stored in Firestore — they go to Google Sheets via Apps Script.
//  - Nobody can edit or delete entries from the browser.
//  - To delete a guestbook message, do it from the Firebase console directly.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /guestbook/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasOnly(['name', 'text', 'when']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 80 &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() < 1000;
      allow update, delete: if false;
    }

  }
}
