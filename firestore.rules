// ── FIRESTORE RULES ─────────────────────────────────────────────────────────
// Paste into: Firebase Console → Firestore → Rules → Publish
//
//  - Guestbook: anyone can read & create (size-limited). No edits/deletes.
//  - Gallery:   anyone can read (photos show on public site).
//              Write/delete is blocked from the browser — uploads go through
//              Firebase Storage directly via the admin page (Storage rules handle auth).

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /guestbook/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasOnly(['name', 'text', 'when']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 80 &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() < 1000;
      allow update, delete: if false;
    }

    match /gallery/{id} {
      allow read: if true;
      // Writes come from admin.html — no server-side auth, so allow write.
      // To lock this down further, enable Firebase Auth and restrict to a known UID.
      allow write: if true;
    }

  }
}

